PRODUCTION_SECRETS=$(kamal secrets fetch --adapter 1password --account my --from Compiler/production KAMAL_REGISTRY_USERNAME KAMAL_REGISTRY_PASSWORD DATABASE_URL TOKEN_ENCRYPTION_KEY GITHUB_APP_ID GITHUB_APP_SLUG GITHUB_APP_PRIVATE_KEY)

KAMAL_REGISTRY_USERNAME=$(kamal secrets extract KAMAL_REGISTRY_USERNAME $PRODUCTION_SECRETS)
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD $PRODUCTION_SECRETS)
DATABASE_URL=$(kamal secrets extract DATABASE_URL $PRODUCTION_SECRETS)
TOKEN_ENCRYPTION_KEY=$(kamal secrets extract TOKEN_ENCRYPTION_KEY $PRODUCTION_SECRETS)
GITHUB_APP_ID=$(kamal secrets extract GITHUB_APP_ID $PRODUCTION_SECRETS)
GITHUB_APP_SLUG=$(kamal secrets extract GITHUB_APP_SLUG $PRODUCTION_SECRETS)
GITHUB_APP_PRIVATE_KEY=$(kamal secrets extract GITHUB_APP_PRIVATE_KEY $PRODUCTION_SECRETS)
