# App Mode: "self-hosted" (default) or "saas"
# APP_MODE=self-hosted

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://compiler:compiler@db:5432/compiler

# Encryption key for credentials (32 bytes hex, 64 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Public URL (optional, for SSO/SAML when behind a reverse proxy or custom domain)
# PUBLIC_URL=https://compiler.thelookoutway.net

# GitHub personal access token (for pushing branches and creating PRs from devcontainer)
# Create at: GitHub > Settings > Developer settings > Personal access tokens
# GH_TOKEN=

# Cloudflare Tunnel token (optional, for exposing local dev server)
# TUNNEL_TOKEN=

# --- SaaS mode only ---

# GitHub App
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_WEBHOOK_SECRET=

# E2B sandbox
# E2B_API_KEY=

# Anthropic API key
# ANTHROPIC_API_KEY=
